FROM node:20-slim

RUN npm install -g pnpm

WORKDIR /app

# Copy root monorepo files
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml ./

# Copy storefront app files
COPY apps/storefront ./apps/storefront

# Remove patchedDependencies before install — Razorpay patch is backend-only
RUN node -e "const fs=require('fs'),p=JSON.parse(fs.readFileSync('package.json','utf8')); delete p?.pnpm?.patchedDependencies; fs.writeFileSync('package.json',JSON.stringify(p,null,2))"

RUN pnpm install

WORKDIR /app/apps/storefront

EXPOSE 8001

CMD ["pnpm", "run", "dev"]
