# Medusa Configuration
# BACKEND_CORS_ORIGIN is derived from HOST in docker-compose

# Secrets (Change these in production)
BACKEND_JWT_SECRET=supersecret
BACKEND_COOKIE_SECRET=supersecret

# Strapi Integration
# STRAPI_URL is set by docker-compose (http://cms:1337)
CMS_API_TOKEN=your_token_here

# Razorpay Configuration
RAZORPAY_ID=rzp_test_template
RAZORPAY_SECRET=your_secret_here
RAZORPAY_ACCOUNT=your_account_id_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Google SMTP Configuration
GOOGLE_SMTP_USER=your-email@gmail.com
GOOGLE_SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ADMIN_NOTIFICATION_EMAIL=

# Interakt — WhatsApp Business API
# Value is base64(api_key:) — copy it directly from the Interakt dashboard Basic Auth token
INTERAKT_API_KEY=your_base64_interakt_token_here

