# Medusa Configuration
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
STORE_CORS=http://localhost:8001
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8001

# Secrets (Change these in production)
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medusa_db
REDIS_URL=redis://localhost:6379

# Strapi Integration
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_token_here

# Razorpay Configuration
RAZORPAY_ID=rzp_test_template
RAZORPAY_SECRET=your_secret_here
